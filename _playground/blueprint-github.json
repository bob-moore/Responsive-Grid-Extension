{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"landingPage": "/wp-admin/post.php?post=2&action=edit",
	"login": true,
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "updateUserMeta",
			"meta": {
				"admin_color": "modern",
				"show_welcome_panel": 0
			},
			"userId": 1
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Responsive Grid Extension"
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/bob-moore/Responsive-Grid-Extension/releases/latest/download/responsive-grid-extension.zip"
			}
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "wordpress.org/themes",
				"slug": "twentytwentyfive"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/bob-moore/Responsive-Grid-Extension/main/_playground/demo-content.xml"
			}
		}
	]
}
